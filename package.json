{
  "name": "loopstacks-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "LSR — Loop Stack Runtime. Reference implementation of LSEM.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
